# Build/runtime artifacts that must not ship into the image.
# node_modules is the big one (665M of host-arch deps) — npm install rebuilds
# the correct arch inside the image; copying the host's would bloat every layer
# and can mismatch architectures.
node_modules
.venv
dist

# Runtime-generated data — recreated on each run, not baked in.
employees
telemetry

# Machine-generated Flue workflows (gitignored) — regenerated by the build
# scripts (onboard:build / aiops:build / run:design), not shipped.
src/workflows/gen-*.ts

# Secrets + VCS + editor noise.
.env
.env.local
.git
.gitignore
*.log

# CI/docs that don't help the runtime.
.github
