{
  "name": "baton-bpmn",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Static reliability analysis for BPMN 2.0 processes — the SonarQube for business processes. Detects deadlocks, dead branches, and stalled approvals BEFORE you deploy. Local-first, CI-friendly, engine-agnostic.",
  "keywords": [
    "bpmn",
    "bpmn2",
    "soundness",
    "static-analysis",
    "workflow",
    "process-mining",
    "camunda",
    "linter",
    "ci",
    "reliability",
    "petri-net",
    "business-process",
    "escalation",
    "stall"
  ],
  "license": "MIT",
  "author": "Adrian Puiu <adrianpuiu@gmail.com>",
  "homepage": "https://github.com/adrianpuiu/Baton#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianpuiu/Baton.git"
  },
  "bugs": {
    "url": "https://github.com/adrianpuiu/Baton/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --import tsx --test test/*.test.ts",
    "test:compiler": "node --import tsx --test test/compiler.test.ts test/parse-errors.test.ts",
    "test:render": "node --import tsx --test test/render.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check:soundness": "tsx scripts/check-soundness.ts",
    "resolve:skills": "tsx scripts/test-resolver.ts",
    "lock:skills": "tsx scripts/lock-skills.ts",
    "generate:skills": "tsx scripts/generate-skills.ts",
    "metrics": "tsx scripts/metrics.ts",
    "aiops:build": "tsx scripts/build-aiops.ts",
    "onboard:build": "tsx scripts/build-onboarding.ts",
    "onboard:demo": "tsx scripts/onboard-demo.ts",
    "dev": "flue dev --target node",
    "build": "flue build --target node",
    "build:cli": "tsc -p tsconfig.cli.json",
    "rfp:build": "tsx scripts/build-rfp.ts",
    "prepublishOnly": "npm run build:cli",
    "start": "node dist/server.mjs",
    "run:design": "flue run design-process --target node",
    "venv": "python3 -m venv .venv && . .venv/bin/activate && pip install -U pip processpiper"
  },
  "bin": {
    "baton": "dist-cli/cli.js"
  },
  "files": [
    "dist-cli",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "fast-xml-parser": "^5.9.2"
  },
  "devDependencies": {
    "@flue/runtime": "latest",
    "hono": "^4.6.0",
    "valibot": "^1.0.0",
    "@flue/cli": "latest",
    "@flue/opentelemetry": "latest",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/resources": "^1.28.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/sdk-trace-base": "^1.28.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.0"
  }
}
