# ---- Local vLLM (OpenAI-compatible) ----
# vLLM ignores the API key, but Flue's provider expects a non-empty string.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=vllm
VLLM_MODEL=Capybara

# Python interpreter that has `processpiper` installed (project .venv by default).
PYTHON=.venv/bin/python
