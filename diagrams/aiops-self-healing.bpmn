      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_execution_agent" bpmnElement="lane_execution_agent">
        <dc:Bounds x="100" y="1200" width="5600" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_validation_agent" bpmnElement="lane_validation_agent">
        <dc:Bounds x="100" y="1360" width="5600" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_recovery_agent" bpmnElement="lane_recovery_agent">
        <dc:Bounds x="100" y="1520" width="5600" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_learning_agent" bpmnElement="lane_learning_agent">
        <dc:Bounds x="100" y="1680" width="5600" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_escalation_agent" bpmnElement="lane_escalation_agent">
